# Local backups of the original server dump — kept on disk as a safety net,
# but not version-controlled (git itself is the history now, and they're large).
*.tar.gz
*.zip

# Agent / editor state
.claude/
.vscode/

# Runtime data — generated by the app, persisted in Docker named volumes.
app/web/results/*
app/web/sessions/*
app/web/templates/sessions/*

# OS noise
Thumbs.db
.DS_Store
