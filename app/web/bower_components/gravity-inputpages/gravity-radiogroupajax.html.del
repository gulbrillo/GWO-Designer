<link rel="import" href="../../bower_components/polymer/polymer.html">
<link href="../../bower_components/paper-radio-group/paper-radio-group.html" rel="import">
<link rel="import" href="../../bower_components/core-ajax/core-ajax.html">



<polymer-element name="gravity-radiogroupajax" extends="paper-radio-group" attributes="hidetip position json parameter">

<template>
	<style>

:host  {
  outline: none;
  margin-bottom: 12px;
  display: block;
}

	</style>

    <core-ajax auto url="{{json}}" handleAs="json" response="{{response}}"></core-ajax>

<shadow></shadow>


</template>

  <script>
  Polymer('gravity-radiogroupajax', {

selected: '0',
parameter: '',

json: 'templates/lisa.json',

   responseChanged: function(e) {

this.label = 'Error: uninitialized';
var parameter = this.response.feed.parameters[this.parameter];
     this.label = parameter.name;
     this.value = parameter.value;
     this.name = this.parameter;
     this.parametertip = parameter.description;
   }

});

  </script>


</polymer-element>
