<link rel="import" href="../../bower_components/polymer/polymer.html">
<link href="../../bower_components/gravity-inputpages/gravity-radio.html" rel="import">
<link href="../../bower_components/gravity-tooltip/core-tooltip.html" rel="import">
<link href="../../bower_components/paper-radio-group/paper-radio-group.html" rel="import">
<link rel="import" href="../../bower_components/core-ajax/core-ajax.html">


<polymer-element name="gravity-radioajax" extends="paper-radio-group" attributes="hidetip position parval pardesc parameter">

  <template>

        <style>

    paper-radio-group /deep/  #ink[checked] {
      color: #00acc1;
    }

    paper-radio-group /deep/  #onRadio {
      background-color: #00acc1;
    }

:host /deep/ *:focus {
    outline: none;
}

:host {
  outline: none;
  display: block;
}



paper-radio-group /deep/ core-tooltip .inner-tip {
width:260px;
white-space:normal;
}

    paper-radio-group /deep/ gravity-radio .core-selected /deep/ #radioLabel {
      font-weight: bold;
    }
   
    paper-radio-group /deep/ gravity-radio {
	display: block;
	cursor: pointer;
    }

     paper-radio-group {
     padding: 3px 0;
     display: block;
     margin-bottom: 12px;
    }

    div.radio-headline {
        font-size: 0.85em;
        display: block;
	 padding: 0;
    }


	core-ajax {display:none;}

        </style>

<core-ajax auto url="{{pardesc}}" handleAs="json" response="{{response}}"></core-ajax>

<div class="radio-headline">{{description.name}}</div>

<paper-radio-group selected="{{selected}}">

      <template repeat="{{e in options}}">

<gravity-radio name="{{e.value}}" label="{{e.name}}"  hidetip?="{{hidetip}}"  position="{{position}} checked?={{ e.value | equalsSelected }}">
<div tip>{{e.description}}</div>
</gravity-radio>


      </template>

</paper-radio-group>

  </template>
  <script>
    Polymer('gravity-radioajax', {

    parameter: '',
    hidetip: false,
    position: 'bottom',
    pardesc: 'templates/lisa.json',
    parval: 'templates/lisa.json',
    options: null,
    description: null,

       responseChanged: function(e) {
	this.options = this.response.feed.parameters[this.parameter].options;
	this.description = this.response.feed.parameters[this.parameter].description;
	this.selected = this.description.selected;
	console.log("I WAS CHANGED");
   },
	equalsSelected: function(value) {
	return value === this.selected; //return true if value of Conditional attribute equals {{selected}}
	}

    });
  </script>

</polymer-element>
